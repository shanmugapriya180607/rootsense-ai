# =============================================================================
# RootSense AI — Environment Variables
# Copy this file to `.env.local` and fill in real values for local dev.
# =============================================================================

# --- AI Provider ---------------------------------------------------------------
# Optional. If unset the app falls back to realistic mock AI responses,
# so the demo works out of the box.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Auth ----------------------------------------------------------------------
# 32+ char random string. Used to sign session tokens in production.
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Database (Prisma, optional) -----------------------------------------------
# Not required to run the demo. Used only if you flip on the Prisma layer.
DATABASE_URL=postgresql://user:password@localhost:5432/rootsense

# --- Integrations (optional, UI only) ------------------------------------------
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# --- App -----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="RootSense AI"
NEXT_PUBLIC_APP_URL=http://localhost:3000
